{
  "name": "copilot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./dist/*": "./dist/*"
  },
  "publishConfig": {
    "main": "./dist/copilot.js",
    "module": "./dist/copilot.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/types/index.d.ts",
        "import": "./dist/copilot.js"
      },
      "./style.css": "./dist/style.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vue-tsc --build && vite build",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
